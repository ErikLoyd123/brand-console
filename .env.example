# LinkedIn app client ID (LinkedIn Developer Portal > your app > Auth).
LINKEDIN_CLIENT_ID=
# LinkedIn app client secret. Never commit the real value.
LINKEDIN_CLIENT_SECRET=
# Must exactly match an authorized redirect URL configured on the LinkedIn app.
LINKEDIN_REDIRECT_URI=http://localhost:5174/api/auth/linkedin/callback

# Reddit has no credentials here: it's a manual copy-paste channel, not an API
# integration. Draft Reddit posts in the console and use "Copy to publish".

# Optional: Unsplash API access key (bring your own — unsplash.com/developers).
# Enables the imagery skill's stock-photo source and the console's Unsplash
# search proxy. Server-side only; never reaches the browser. Leave empty to
# skip Unsplash — composed graphics and screenshots work without it.
UNSPLASH_ACCESS_KEY=

# Local photoreal image generation (no key, no cloud) is configured in a separate
# file, not here: copy image-generation.config.example.json to
# image-generation.config.json (gitignored). Default backend "mflux" is fully headless
# (no app): FLUX.1 [schnell] via MLX — install once with `uv tool install mflux`, first
# run downloads the weights. Alternate "drawthings" drives the Draw Things app's local
# API instead. Leave it unconfigured to skip — the imagery skill degrades gracefully and
# still offers the other image types.

# Optional override for the embedded console terminal (the "Terminal" button).
# Leave empty on macOS/Linux: claude is launched through your login shell, which
# resolves it from your PATH the same way typing `claude` does. Set this to an
# absolute path if claude isn't on your shell PATH or you're on Windows, e.g.
# CLAUDE_BIN=/Users/you/.local/bin/claude   (macOS/Linux)
# CLAUDE_BIN=C:\Users\you\.local\bin\claude.exe   (Windows)
CLAUDE_BIN=
