  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.5",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.4",
    "express": "^4.21.2",
    "nanoid": "^5.0.9",
    "node-pty": "^1.0.0",
    "playwright": "^1.61.1",
    "rss-parser": "^3.13.0",
    "sharp": "^0.35.3",
    "ws": "^8.18.0",
    "yaml": "^2.6.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
